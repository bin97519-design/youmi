{
  "manifest_version": 3,
  "name": "Youmi DOM Style Collector",
  "description": "Collect rendered DOM structure, bounding boxes, computed styles, assets, and key layout targets for reconstruction.",
  "version": "0.1.0",
  "permissions": ["activeTab", "downloads", "scripting"],
  "host_permissions": ["https://youqianai.com/*", "https://*.youqianai.com/*", "http://127.0.0.1/*", "http://localhost/*"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "DOM Style Collector"
  },
  "content_scripts": [
    {
      "matches": ["https://youqianai.com/*", "https://*.youqianai.com/*", "http://127.0.0.1/*", "http://localhost/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}

# ============================================================
#  有米 AI (youmi) —— 统一仓库根 .gitignore
#  结构：/frontend (Vue/Vite)   /backend (Spring Boot)
# ============================================================

# ===================== 前端 Frontend (Vue / Vite) =====================
node_modules/
dist/
build/
coverage/
.vite/
.output/
*.local

# 前端环境 / 密钥（绝不入库）
.env
.env.*

# ===================== 后端 Backend (Spring Boot) =====================
# 构建产物
target/
BOOT-INF/
temp_jar/
jar-patch/
**/*.class
**/*.jar

# Maven wrapper 自动下载的发行版
**/apache-maven-/

# 含密钥 / 本地配置（绝不入库，防止泄露）
config/
config-external/
gettoken-override.yml
**/application-dev.yml
**/application-prod.yml

# 运行时数据
logs/
uploads/
data/
tmp/
_nul

# ===================== 通用 / 跨项目 =====================
# Python 调试遗留（不入仓库）
__pycache__/
*.pyc
mini-redis.py
proxy_log.py

# 日志
*.log
*.err.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 缓存
.eslintcache
.parcel-cache/
.cache
*.tsbuildinfo

# IDE / OS
.idea/
*.iml
.vscode/
.DS_Store
Thumbs.db
*.swp
*.swo

# 运行时 pid
pids
*.pid
*.seed
*.pid.lock

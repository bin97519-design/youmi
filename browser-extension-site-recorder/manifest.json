{
  "manifest_version": 3,
  "name": "Youmi Site Structure Recorder",
  "description": "Record frontend structure, navigation, user actions, and network summaries for site reconstruction research.",
  "version": "0.1.5",
  "permissions": ["activeTab", "contextMenus", "downloads", "scripting", "storage", "tabs"],
  "host_permissions": [
    "<all_urls>",
    "https://youqianai.com/*",
    "https://*.youqianai.com/*",
    "https://api.youqianai.com/*",
    "https://detail.tmall.com/*",
    "http://127.0.0.1:5173/*",
    "http://127.0.0.1:5174/*",
    "http://localhost:5174/*",
    "http://127.0.0.1:8080/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Site Recorder"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/injected.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
